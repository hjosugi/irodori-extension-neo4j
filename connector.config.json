        "id": "graph-cypher-degree-centrality",
        "label": "Degree centrality starter",
        "language": "cypher",
        "description": "Find highly connected nodes without requiring a projected algorithm graph.",
        "insertText": "MATCH (n)--()\nRETURN n, count(*) AS degree\nORDER BY degree DESC\nLIMIT $limit",
        "parameters": [
          {
            "id": "limit",
            "label": "Limit",
            "type": "number",
            "default": 25
          }
        ],
        "resultView": "table"
