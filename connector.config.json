    "knowledgeEngineStatus": "wired",
    "adapter": "db/neo4j.rs",
    "adapterSha256": "ec1edf1dc6ae2cdb2b6b7c01054cf72ff50fe76dbca7a4c382fc4b3e9ee8fe2a"
