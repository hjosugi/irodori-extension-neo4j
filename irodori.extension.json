{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.neo4j",
  "name": "Neo4j Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "Neo4j Connector contributes the Neo4j database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-neo4j",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "neo4j.connector",
        "engine": "neo4j",
        "label": "Neo4j",
        "aliases": [
          "neo4j",
          "Neo4j"
        ],
        "defaultPort": 7687,
        "wire": "neo4j",
        "module": "neo4j.driver",
        "features": [
          "metadata",
          "streaming",
          "graph",
          "graphVisualization",
          "pathFinding",
          "graphAlgorithms",
          "queryTemplates",
          "visualization"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "neo4j",
            "wire": "neo4j",
            "port": 7687,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "hostPort",
              "connectionString"
            ],
            "defaultPort": 7687,
            "fields": [
              {
                "id": "host",
                "label": "Host",
                "type": "string",
                "profileField": "host",
                "required": true
              },
              {
                "id": "port",
                "label": "Port",
                "type": "number",
                "profileField": "port",
                "default": 7687
              },
              {
                "id": "database",
                "label": "Database",
                "type": "string",
                "profileField": "database"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "host",
              "label": "Host",
              "type": "string",
              "profileField": "host",
              "required": true
            },
            {
              "id": "port",
              "label": "Port",
              "type": "number",
              "profileField": "port",
              "default": 7687
            },
            {
              "id": "database",
              "label": "Database",
              "type": "string",
              "profileField": "database"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "basic",
              "label": "Basic authentication",
              "kind": "userPassword",
              "secretPurposes": [
                "password"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "password",
                  "label": "Password",
                  "type": "secret",
                  "secretPurpose": "password",
                  "profileField": "password"
                }
              ]
            },
            {
              "id": "kerberos",
              "label": "Kerberos / GSSAPI",
              "kind": "kerberos",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "principal",
                  "label": "Principal",
                  "type": "string"
                },
                {
                  "id": "keytab",
                  "label": "Keytab",
                  "type": "path",
                  "secretPurpose": "privateKey"
                }
              ]
            },
            {
              "id": "bearerToken",
              "label": "Bearer token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "clientCertificate",
              "label": "Client certificate / mTLS",
              "kind": "certificate",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "clientCertificate",
                  "label": "Client certificate",
                  "type": "pem"
                },
                {
                  "id": "clientPrivateKey",
                  "label": "Client private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "clientPrivateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "password",
            "token",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": false,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "neo4j"
          ],
          "customDriverOptions": true
        },
        "experience": {
          "schemaVersion": 1,
          "domains": [
            "graph"
          ],
          "inspiredBy": [
            "Neo4j Browser",
            "Neo4j Bloom",
            "Neo4j Graph Data Science",
            "Cypher shortest path"
          ],
          "resultViews": [
            "graph",
            "path",
            "table"
          ],
          "objectTypes": [
            "nodeLabels",
            "relationshipTypes",
            "properties",
            "indexes",
            "constraints"
          ],
          "workflows": [
            {
              "id": "graph-schema-overview",
              "label": "Schema overview",
              "description": "Summarize labels and relationship types before exploration.",
              "resultView": "table",
              "templateIds": [
                "graph-cypher-label-counts"
              ]
            },
            {
              "id": "graph-neighborhood",
              "label": "Explore neighborhood",
              "description": "Return connected nodes and relationships around a node.",
              "resultView": "graph",
              "templateIds": [
                "graph-cypher-neighborhood"
              ]
            },
            {
              "id": "graph-shortest-path",
              "label": "Shortest path",
              "description": "Find a bounded shortest path between source and target nodes.",
              "resultView": "path",
              "templateIds": [
                "graph-cypher-shortest-path"
              ]
            },
            {
              "id": "graph-algorithm-starter",
              "label": "Algorithm starter",
              "description": "Open centrality and community-detection starter queries.",
              "resultView": "table",
              "templateIds": [
                "graph-cypher-degree-centrality"
              ]
            }
          ],
          "queryTemplates": [
            {
              "id": "graph-cypher-label-counts",
              "label": "Label counts",
              "language": "cypher",
              "description": "Count nodes by label for a quick schema read.",
              "insertText": "MATCH (n)\nRETURN labels(n) AS labels, count(*) AS count\nORDER BY count DESC",
              "parameters": [],
              "resultView": "table"
            },
            {
              "id": "graph-cypher-neighborhood",
              "label": "Neighborhood graph",
              "language": "cypher",
              "description": "Render a small relationship neighborhood.",
              "insertText": "MATCH (n)-[r]->(m)\nRETURN n, r, m\nLIMIT $limit",
              "parameters": [
                {
                  "id": "limit",
                  "label": "Limit",
                  "type": "number",
                  "default": 100
                }
              ],
              "resultView": "graph"
            },
            {
              "id": "graph-cypher-shortest-path",
              "label": "Shortest path",
              "language": "cypher",
              "description": "Find a bounded shortest path between two nodes.",
              "insertText": "MATCH p = shortestPath((source {id: $sourceId})-[*..6]-(target {id: $targetId}))\nRETURN p",
              "parameters": [
                {
                  "id": "sourceId",
                  "label": "Source id",
                  "type": "string"
                },
                {
                  "id": "targetId",
                  "label": "Target id",
                  "type": "string"
                }
              ],
              "resultView": "path"
            },
            {
              "id": "graph-cypher-degree-centrality",
              "label": "Degree centrality starter",
              "language": "cypher",
              "description": "Find highly connected nodes without requiring a projected algorithm graph.",
              "insertText": "MATCH (n)--()\nRETURN n, count(*) AS degree\nORDER BY degree DESC\nLIMIT $limit",
              "parameters": [
                {
                  "id": "limit",
                  "label": "Limit",
                  "type": "number",
                  "default": 25
                }
              ],
              "resultView": "table"
            }
          ],
          "inspectorHints": [
            {
              "id": "graph-node-labels",
              "label": "Label browser",
              "description": "Show labels, relationship types, and sample properties together."
            },
            {
              "id": "graph-expand-depth",
              "label": "Depth control",
              "description": "Offer one, two, and three hop expansion presets."
            }
          ]
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "neo4j.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
